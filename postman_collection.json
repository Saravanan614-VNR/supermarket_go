		{
			"name": "Sales (POS Checkout)",
			"item": [
				{
					"name": "Open Sale (ADMIN/CASHIER)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    if (body.id) {",
									"        pm.collectionVariables.set('saleId', body.id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"clientId\": {{clientId}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/sales",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "sales" ]
						},
						"description": "clientId is optional (omit or null for a guest/walk-in sale). On success, saves the returned sale id into {{saleId}}."
					},
					"response": []
				},
