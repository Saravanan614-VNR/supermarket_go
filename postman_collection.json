						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"John Doe\",\n  \"username\": \"johndoe123\",\n  \"password\": \"SecretP@ss123\",\n  \"role\": \"CASHIER\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/users",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users" ]
						},
						"description": "role must be one of ADMIN, CASHIER, INVENTORY."
					},
					"response": []
				},
				{
					"name": "List Users (ADMIN only)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users?page=1&size=10",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users" ],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "size", "value": "10" }
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete User (ADMIN only)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/{{userId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users", "{{userId}}" ]
						}
					},
					"response": []
				}
			]
		},
