{
	"info": {
		"_postman_id": "b6f2a1b0-6a0e-4d3a-9b6d-supermarket-backend",
		"name": "SupermarketService API",
		"description": "Postman collection for all endpoints registered in controllers/router.go (RegisterRoutes). Base URL and JWT token are driven by collection variables so requests can be run end-to-end: Login -> token auto-saved -> use on subsequent requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{authToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
		{ "key": "authToken", "value": "", "type": "string" },
		{ "key": "userId", "value": "1", "type": "string" },
		{ "key": "categoryId", "value": "1", "type": "string" },
		{ "key": "clientId", "value": "1", "type": "string" },
		{ "key": "productId", "value": "1", "type": "string" },
		{ "key": "promotionId", "value": "1", "type": "string" },
		{ "key": "saleId", "value": "1", "type": "string" },
		{ "key": "itemId", "value": "1", "type": "string" }
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/healthz",
							"host": [ "{{baseUrl}}" ],
							"path": [ "healthz" ]
						},
						"description": "Liveness/readiness probe. Unauthenticated."
					},
					"response": []
				}
			]
		},
		{
			"name": "Users / Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    if (body.token) {",
									"        pm.collectionVariables.set('authToken', body.token);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe123\",\n  \"password\": \"SecretP@ss123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/login",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users", "login" ]
						},
						"description": "Public login. On success, saves the returned JWT into the {{authToken}} collection variable for use by all other requests."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/logout",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users", "logout" ]
						},
						"description": "Revokes the current bearer token (adds it to the blacklist). Any authenticated operator."
					},
					"response": []
				},
				{
					"name": "Get User By ID (Self or ADMIN)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/{{userId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users", "{{userId}}" ]
						},
						"description": "Non-admin operators may only fetch their own profile (path :id must match the JWT subject)."
					},
					"response": []
				},
				{
					"name": "Update User (Self or ADMIN)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"John Updated Doe\",\n  \"password\": \"NewSecretP@ss123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/{{userId}}",
							"host": [ "{{baseUrl}}" ],
							"path": [ "api", "v1", "users", "{{userId}}" ]
						},
						"description": "All fields optional. Non-admin operators may only update their own profile."
					},
					"response": []
				},
