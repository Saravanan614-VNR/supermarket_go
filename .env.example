# Copy this file to .env and fill in real values for your machine.
# .env is git-ignored - never commit real secrets/credentials.

PORT=8080
APP_ENV=development
LOG_LEVEL=debug

# Comma-separated list of origins allowed to make cross-origin requests.
# Leave empty to disable CORS entirely (no browser origin trusted).
ALLOWED_ORIGINS=http://localhost:3000

MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/super-market?charset=utf8mb4&parseTime=True&loc=Local

DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINS=30

# Optional in development (a dev-safe fallback secret is used if empty).
# Required in production (APP_ENV=production) - must be a strong random value.
JWT_SECRET=

CACHE_NUM_COUNTERS=10000
CACHE_MAX_COST=104857600
CACHE_BUFFER_ITEMS=64
